# ---------------------------------------------------------------------------
# FastAPI server settings
# ---------------------------------------------------------------------------
HOST=127.0.0.1
PORT=8001

# ---------------------------------------------------------------------------
# Vanna mode
# ---------------------------------------------------------------------------
# Use "legacy_vanna" for the official vn.generate_sql / vn.run_sql / vn.train
# workflow shown in the Vanna legacy docs.
VANNA_MODE=legacy_vanna

# ---------------------------------------------------------------------------
# Vanna model credentials
# ---------------------------------------------------------------------------
# For the classic hosted Vanna flow, set the values below from your Vanna
# account / model setup.
VANNA_API_KEY=your_vanna_api_key
VANNA_MODEL_NAME=your_vanna_model_name

# ---------------------------------------------------------------------------
# Database connection for GroceMate
# ---------------------------------------------------------------------------
# IMPORTANT: create a dedicated read-only database user for the chatbot.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=grocemate
DB_USER=grocemate_readonly
DB_PASSWORD=change_me

# ---------------------------------------------------------------------------
# SQL safety controls
# ---------------------------------------------------------------------------
MAX_RESULT_ROWS=20
